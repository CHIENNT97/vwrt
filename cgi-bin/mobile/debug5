#!/usr/bin/lua
local cjson = require "cjson"
local function exec(cmd)
    local f = io.popen(cmd)
    if not f then return nil end
    local content = f:read("*all")
    f:close()
    return content
end
print("Content-type: application/json\n\n")
local cache = exec("cat /tmp/cache_info_2_1 2>/dev/null")
local at_res = exec("cat /tmp/at_res_* 2>/dev/null")
print(cjson.encode({ cache = cache, at_res = at_res }))
