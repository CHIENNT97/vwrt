#!/usr/bin/lua

-- Dynamic Path Resolution
local source = debug.getinfo(1).source
local script_path = source:match("@?(.*[\\/])")
if script_path then
    local cgi_root = script_path:match("(.*cgi%-bin/)")
    if cgi_root then
        package.path = cgi_root .. "?.lua;" .. package.path
    end
end
if not package.path:find("/www/NTC_WRT/cgi-bin") then
    package.path = "/www/NTC_WRT/cgi-bin/?.lua;" .. package.path
end

local cjson = require "cjson"
local csrf = require "lib.csrf"

print("Content-type: application/json\n")

local function send_response(status, message)
    print(cjson.encode({ status = status, message = message }))
end

local function get_input()
    local len = tonumber(os.getenv("CONTENT_LENGTH") or 0)
    if len > 0 then
        local raw = io.read(len)
        return cjson.decode(raw)
    end
    return nil
end

local input = get_input()

-- CSRF Check
local token = csrf.get_token_from_request() or (input and input.csrf_token)
if not csrf.validate_token(token) then
    send_response("error", "CSRF Token khÃ´ng há»£p lá»‡!")
    os.exit()
end

if not input then
    send_response("error", "No data received")
    os.exit()
end

local user = input.username
local pass = input.password

if not user or user == "" or not pass or pass == "" then
    send_response("error", "Missing username or password")
    os.exit()
end

-- Validate user (basic check)
if user ~= "root" and user ~= "admin" then
    send_response("error", "Only root/admin allowed")
    os.exit()
end

-- Execute passwd command
-- OpenWrt: echo -e "password\npassword" | passwd root
local cmd = string.format("echo -e '%s\\n%s' | passwd %s >/dev/null 2>&1", pass, pass, user)
local result = os.execute(cmd)

if result == 0 or result == true then
    send_response("success", "ÄÃ£ Ä‘á»•i máº­t kháº©u thÃ nh cÃ´ng cho user: " .. user)
else
    send_response("error", "Lá»—i há»‡ thá»‘ng khi Ä‘á»•i máº­t kháº©u")
end

